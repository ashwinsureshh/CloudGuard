# ── CloudGuard — Environment Configuration ────────────────────────────────────
# Cloud Computing / 12-Factor App: all config comes from environment variables.
# Copy this file to .env and set values before running.

# ── Security (Cryptography) ────────────────────────────────────────────────────
# JWT signing secret — change this in production!
SECRET_KEY=cloudguard-jwt-secret-change-in-production

# HMAC key for alert integrity signing
HMAC_KEY=cloudguard-hmac-secret-change-in-production

# JWT token expiry in seconds (default 1 hour)
JWT_EXPIRY_S=3600

# ── Infrastructure (Cloud Computing) ──────────────────────────────────────────
# Kafka broker address
KAFKA_BROKER=localhost:9092

# Redis cache URL
REDIS_URL=redis://localhost:6379/0

# Cache TTL (seconds)
CACHE_STATS_TTL=5
CACHE_ALERTS_TTL=10

# ── Web (CORS) ─────────────────────────────────────────────────────────────────
# Allowed CORS origin for the API
CORS_ORIGIN=http://localhost:3000
